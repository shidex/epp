# Setting Mandatory
SERVER_PORT=700
SERVER_SSL_ENABLED=true
AUTHBACKEND_URL=http://be.pandi.id:8080/PANDI-REGISTRAR-0.1/authRegistrar/
BACKEND_URL=http://be.pandi.id:8080/PANDI-CORE-0.1/processepp/
LOGOUTBACKEND_URL=http://be.pandi.id:8080/PANDI-REGISTRAR-0.1/logoutRegistrar/
IDLE_TIMEOUT_SECONDS=600
TLS_CLIENT_AUTH=NONE
RATELIMIT_IP_RULES=25/second,1500/minute
RATELIMIT_CLIENT_RULES=25/second,1500/minute
RATELIMIT_CHANNEL_RULES=15/second,900/minute
RATELIMIT_WRITE_RULES=40/second,2400/minute
RATELIMIT_READ_RULES=150/second,9000/minute
RATELIMIT_READ_IP_RULES=20/second,1200/minute
RATELIMIT_WRITE_IP_RULES=5/second,300/minute
RATELIMIT_READ_CLIENT_RULES=20/second,1200/minute
RATELIMIT_WRITE_CLIENT_RULES=5/second,300/minute

# Opsional
TLS_SERVER_CERT=certs/server-fullchain.pem
TLS_SERVER_KEY=certs/server.key
TLS_CA_CERT=certs/cacert.pem
EPP_CONNECT_TIMEOUT=5s
EPP_BACKEND_TIMEOUT=15s
EPP_BACKEND_DIAL_TIMEOUT=3s
EPP_BACKEND_TLS_HANDSHAKE_TIMEOUT=3s
EPP_BACKEND_IDLE_CONN_TIMEOUT=90s
EPP_BACKEND_MAX_IDLE_CONNS=2048
EPP_BACKEND_MAX_IDLE_CONNS_PER_HOST=1024
EPP_BACKEND_MAX_CONNS_PER_HOST=0
EPP_BACKEND_RESPONSE_MAX_BYTES=1048576
EPP_WRITE_TIMEOUT=10s
EPP_MAX_FRAME_BYTES=65535
EPP_MAX_CONNS=1000
EPP_RATELIMIT_MAX_KEYS=100000
EPP_LOG_FORMAT=json
EPP_REALTIME_STATS_FILE=logs/realtime-stats.json
EPP_REALTIME_STATS_INTERVAL=5s
EPP_REALTIME_STATS_WRITE_TIMEOUT=1s
